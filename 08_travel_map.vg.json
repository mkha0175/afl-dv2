{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Travel heatmap: 18 clubs by 36 seasons (1990-2025). Each cell is shaded by the total kilometres a club flew that season (derived data: sum of haversine distance from the club's home city to every venue they played). Reading down a column shows the spread of travel within a season; reading across a row shows how a club's travel has grown as the fixture has expanded.",
  "width": "container",
  "height": 460,
  "background": "white",
  "config": {
    "view": {"stroke": null},
    "font": "Inter, system-ui, sans-serif"
  },
  "data": {"url": "travel.csv"},
  "transform": [
    {"lookup": "team",
     "from": {"data": {"url": "teams.csv"}, "key": "name", "fields": ["state", "debut"]}},
    {"filter": "datum.km > 0"}
  ],
  "mark": {"type": "rect", "stroke": "white", "strokeWidth": 0.8},
  "encoding": {
    "x": {"field": "year", "type": "ordinal", "title": null,
          "axis": {"labelAngle": -45, "labelFontSize": 9, "labelOverlap": true, "ticks": false, "domain": false}},
    "y": {"field": "team", "type": "nominal", "title": null,
          "sort": {"op": "median", "field": "km", "order": "descending"},
          "axis": {"labelFontWeight": 600, "labelFontSize": 10, "ticks": false, "domain": false}},
    "color": {
      "field": "km", "type": "quantitative",
      "scale": {"scheme": "oranges", "type": "linear"},
      "title": "km flown in season",
      "legend": {"orient": "right", "format": ",.0f"}
    },
    "tooltip": [
      {"field": "team", "title": "Club"},
      {"field": "year", "title": "Season"},
      {"field": "state", "title": "Home state"},
      {"field": "km", "title": "Distance flown (km)", "format": ","}
    ]
  }
}
