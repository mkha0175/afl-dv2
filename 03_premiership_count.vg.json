{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Premiership trophy cabinet 1990-2025. Each Grand Final win is rendered as a single trophy emoji laid out in a row per club; clubs are sorted top-to-bottom by total flag count. Each trophy carries the winning year beneath it; the bold number at the right is the club's total. Hover any trophy for the full Grand Final result.",
  "width": "container",
  "height": {"step": 50},
  "background": "white",
  "padding": {"top": 16, "left": 24, "right": 72, "bottom": 22},
  "config": {
    "view": {"stroke": null},
    "font": "Inter, system-ui, sans-serif"
  },
  "data": {"url": "premierships.csv"},
  "transform": [
    {"window": [
       {"op": "row_number", "as": "trophy_idx"},
       {"op": "count",     "as": "total"}
     ], "groupby": ["winner"], "sort": [{"field": "year"}],
     "frame": [null, null]}
  ],
  "encoding": {
    "y": {"field": "winner", "type": "nominal",
          "scale": {"domain": ["Brisbane Lions", "Hawthorn", "Geelong", "West Coast", "Collingwood", "Richmond", "Adelaide", "Essendon", "North Melbourne", "Sydney", "Carlton", "Melbourne", "Port Adelaide", "Western Bulldogs"]},
          "title": null,
          "axis": {"labelFontWeight": 700, "labelFontSize": 12, "labelPadding": 14,
                   "ticks": false, "domain": false, "grid": false}},
    "x": {"field": "trophy_idx", "type": "ordinal", "axis": null,
          "scale": {"paddingInner": 0.1, "paddingOuter": 0.05}}
  },
  "layer": [
    {
      "mark": {"type": "text", "fontSize": 30, "baseline": "middle"},
      "encoding": {
        "text": {"value": "🏆"},
        "tooltip": [
          {"field": "year", "title": "Year"},
          {"field": "winner", "title": "Premier"},
          {"field": "runner_up", "title": "Runner-up"},
          {"field": "winner_score", "title": "Win score"},
          {"field": "loser_score", "title": "Lose score"},
          {"field": "margin", "title": "Margin"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 9, "baseline": "middle", "dy": 19,
               "color": "#7A8294", "fontWeight": 600},
      "encoding": {"text": {"field": "year"}}
    },
    {
      "transform": [{"filter": "datum.trophy_idx == datum.total"}],
      "mark": {"type": "text", "fontSize": 22, "fontWeight": 800, "color": "#08152B",
               "align": "left", "baseline": "middle", "dx": 32},
      "encoding": {"text": {"field": "total"}}
    }
  ]
}
