{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Stacked area chart of where AFL matches were played each season, by host state. Tracks the league's expansion away from Victoria. Colour scheme matches the chart 01 state palette for consistency.",
  "width": "container",
  "height": 320,
  "background": "white",
  "config": {
    "view": {"stroke": null},
    "font": "Inter, system-ui, sans-serif"
  },
  "data": {"url": "venue_state_year.csv"},
  "mark": {"type": "area", "interpolate": "monotone", "opacity": 0.9},
  "encoding": {
    "x": {"field": "year", "type": "quantitative", "title": null,
          "axis": {"format": "d", "grid": false}},
    "y": {"field": "games", "type": "quantitative", "stack": "zero",
          "title": "Matches per season",
          "axis": {"grid": true, "gridColor": "#EAEAEA"}},
    "color": {
      "field": "state", "type": "nominal",
      "scale": {
        "domain": ["VIC", "SA", "WA", "NSW", "QLD", "TAS", "ACT", "NT", "NZ", "CN"],
        "range":  ["#08152B", "#7C0A02", "#1E5E8C", "#B5851A", "#0A6B3E", "#7E5BEF", "#9B59B6", "#E67E22", "#16A085", "#95A5A6"]
      },
      "title": "Host state",
      "legend": {"orient": "top", "direction": "horizontal", "columns": 10, "symbolSize": 100, "titleFontSize": 11, "labelFontSize": 10}
    },
    "tooltip": [
      {"field": "year", "title": "Season"},
      {"field": "state", "title": "State"},
      {"field": "games", "title": "Matches"}
    ]
  }
}
