{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Stacked area chart of where AFL matches were played each season, by host state. Tracks the league's expansion away from Victoria.",
  "width": "container",
  "height": 320,
  "background": "white",
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter, system-ui, sans-serif"
  },
  "data": {
    "url": "data/venue_state_year.csv"
  },
  "mark": {
    "type": "area",
    "interpolate": "monotone",
    "opacity": 0.85
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "title": null,
      "axis": {
        "format": "d",
        "grid": false
      }
    },
    "y": {
      "field": "games",
      "type": "quantitative",
      "stack": "zero",
      "title": "Matches per season",
      "axis": {
        "grid": true,
        "gridColor": "#EAEAEA"
      }
    },
    "color": {
      "field": "state",
      "type": "nominal",
      "scale": {
        "domain": [
          "VIC",
          "WA",
          "SA",
          "NSW",
          "QLD",
          "TAS",
          "ACT",
          "NT",
          "NZ",
          "CN"
        ],
        "range": [
          "#0B2545",
          "#2E86AB",
          "#C0392B",
          "#F39C12",
          "#117A65",
          "#7E5BEF",
          "#9B59B6",
          "#E67E22",
          "#16A085",
          "#95A5A6"
        ]
      },
      "legend": {
        "orient": "top",
        "title": "Host state"
      }
    },
    "tooltip": [
      {
        "field": "year",
        "title": "Season"
      },
      {
        "field": "state",
        "title": "State"
      },
      {
        "field": "games",
        "title": "Matches"
      }
    ]
  }
}